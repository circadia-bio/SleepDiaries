{
  "expo": {
    "name": "Sleep Diaries",
    "slug": "sleep-diaries",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#C8DFF5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.circadia.sleepdiaries"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C8DFF5"
      },
      "package": "com.circadia.sleepdiaries"
    },
    "scheme": "sleep-diaries",
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A7BB5",
          "sounds": []
        }
      ]
    ]
  }
}
